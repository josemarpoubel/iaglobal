# Runtime data (regenerable)
iaglobal/memory/data/

# Obsidian vault files
iaglobal/obsidian/**/*.md
iaglobal/obsidian/**/*.cbor
iaglobal/obsidian/**/search_index.json

.env

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environment
venv/

# Test artifacts
tests/temp/

# Root-level runtime artifacts (avoid accidental commits)
*.db
*.log
*.pkl
*.lock

# Epigenetic state (regenerable)
iaglobal/obsidian/epigenetic/*.cbor

# Build artifacts
iaglobal.egg-info/
*.egg-info/
.goosehints
.opencode.json
.pytest_cache
.ruff_cache

