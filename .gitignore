# Data files and databases
iaglobal/memory/data/db/*.db
iaglobal/memory/data/json/*.json
iaglobal/memory/data/json/*.jsonl
iaglobal/memory/data/json/*.cbor
iaglobal/memory/data/omnimind_state.json
iaglobal/memory/data/provider_metrics/*.jsonl
iaglobal/memory/data/result/.counter.lock
iaglobal/memory/data/tools_registry.pkl
iaglobal/memory/data/ancestry_tree.jsonl

# Obsidian vault files
iaglobal/obsidian/**/*.md
iaglobal/obsidian/**/*.cbor

.env

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environment
venv/

# Runtime artifacts
iaglobal/memory/data/result/*
iaglobal/memory/data/script/*
iaglobal/memory/data/*.log

# Test artifacts
tests/temp/

# Runtime caches and execution artifacts
iaglobal/memory/data/cache/
iaglobal/memory/data/error/
iaglobal/memory/data/work/
iaglobal/memory/data/life_signals.json

# Root-level runtime artifacts (avoid accidental commits)
*.db
*.log
*.pkl
*.lock

# Epigenetic state (regenerable)
iaglobal/obsidian/epigenetic/*.cbor

# Build artifacts
iaglobal.egg-info/
*.egg-info/
.goosehints
.opencode.json
.pytest_cache
.ruff_cache

