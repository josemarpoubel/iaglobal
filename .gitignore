```gitignore
# Python compiled files
*.pyc
__pycache__/

# Database files
*.db

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Coverage reports
coverage/
htmlcov/
.coverage

# Python cache
.mypy_cache/
.pytest_cache/

# Build and distribution
dist/
build/
target/

# Virtual environments
.venv/
venv/
```