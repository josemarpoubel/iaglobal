```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# Test results and temporary data
.tests/
.test_results/
*.tmp
*.temp

# Coverage reports
.coverage
htmlcov/
coverage/

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# OS generated
.DS_Store
Thumbs.db

# Memory data and work files
iaglobal/memory/data/work/
iaglobal/memory/data/result/
iaglobal/memory/data/script/
```