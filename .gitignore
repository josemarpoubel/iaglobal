# Logs
*.log

# Database files
*.db

# Temporary work files
iaglobal/memory/data/work/*/logs.txt
iaglobal/memory/data/work/*/*/logs.txt
iaglobal/memory/data/work/*/*/*/logs.txt

# Generated code files in work directory
iaglobal/memory/data/work/*/code.py
iaglobal/memory/data/work/*/*/code.py
iaglobal/memory/data/work/*/*/*/code.py

# Generated result and script files
iaglobal/memory/data/result/
iaglobal/memory/data/script/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment files
.env
.env.local

# IDE files
.vscode/
.idea/
*.swp
*.swo
.kilo
.opencode
.opencode.json

# OS files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Root artifacts from hardcoded paths (should be inside iaglobal/)
/backup/
/IVMAxiom/
obsidian/

# Test temp artifacts (contents ignored, dir tracked via .gitkeep)
tests/temp/*
!tests/temp/.gitkeep

# Build artifacts
dist/
build/
target/
*.egg-info/

# Dependencies
node_modules/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.gradle/
