# Configuration for IAGlobal v3+ Pipeline
# Copy this to .env before running the pipeline

# FewShot Provider
FEWSHOT_PRELOAD=false

# Provider configuration
PROVIDER_TIMEOUT=120
PROVIDER_FALLBACK_CHAIN=BANDIT_POLICY

# models
OLLAMA_HOST=http://localhost:11434

GROQ_API_KEY=your-groq-api-key-here

NVIDIA_API_KEY=your-nvidia-api-key-here

OPENROUTER_API_KEY=your-openrouter-api-key-here

OPENCODE_API_KEY=your-opencode-api-key-here

GEMINI_API_KEY=your-gemini-api-key-here

POE_API_KEY=your-groq-api-key-here

NVIDIA_API_KEY=your-groq-api-key-here

HUGGINGFACE_API_KEY=your-groq-api-key-here

MISTRAL_API_KEY=your-groq-api-key-here

OPENAI_API_KEY=your-groq-api-key-here

DEFAULT_OLLAMA_MODEL=qwen2.5:0.5b

GITHUB_API_KEY=your-groq-api-key-here

E2B_API_KEY=your-groq-api-key-here


# MCP Server Authentication
MCP_USER=iaglobal
MCP_PASSWORD=homeostasis

# MCP Server Address
MCP_HOST=0.0.0.0
MCP_PORT=8100

# Logging
LOG_LEVEL=info
LOG_TO_FILE=true

# Memory
MEMORY_STORAGE_TYPE=sqlite
MEMORY_PERSISTENCE=true

# Pipeline
PIPELINE_MAX_WORKERS=8
PIPELINE_MAX_RETRY=3
PIPELINE_MAX_LATENCY=120

# Bandit Policy - Inicializa com preferência por modelos cloud
BANDIT_POLICY=epsilon_greedy
epsilon=0.2
# Pesos iniciais: cloud=0.8, local=0.3 (Bandit aprende com o tempo)
BANDIT_INITIAL_WEIGHTS=ollama/qwen2.5:0.5b:1.0

# Sanity Barrier
SANITY_BARRIER_ENABLED=true
SANITY_BARRIER_CRITICAL_NODES=orchestrator_agent,architecture_validator,evaluator,pipeline_updater

# Toxicity Filter
TOXICITY_FILTER=true
TOXICITY_THRESHOLD=0.8

# Resource Limits
MAX_CPU_USAGE=80
MAX_MEMORY_USAGE_MB=8192

# Execution Registry
EXECUTION_REGISTRY_PERSISTENCE=true

# SearXNG (meta-buscador local)
SEARXNG_URL=http://localhost:8005

PIPELINE_TIMEOUT=300

# === CONFIGURAÇÃO COM PROVIDERS CLOUD (Groq + NVIDIA + Ollama) ===
OLLAMA_ONLY=false
SEQUENTIAL_FALLBACK=false
RACE_SIZE=3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b

# Bandit seleciona entre todos os providers disponíveis
PROVIDER_FALLBACK_CHAIN=BANDIT_POLICY

# Desativar RAG que tenta baixar do HuggingFace
DISABLE_RAG=true
DISABLE_EMBEDDINGS=true

# Timeout maior para modelo local lento
RUNNER_TASK_TIMEOUT=600
GRAPH_EXECUTION_TIMEOUT=600

# MCP Server Authentication
MCP_USER=iaglobal
MCP_PASSWORD=homeostasis

# MCP Server Address
MCP_HOST=0.0.0.0
MCP_PORT=8100

# Gateway ASGI (Entry Point Único)
# Porta 8000 é o gateway principal que monta:
#   - /mcp/* → MCP Server (8100 interno)
#   - /@/* → UI ReactPy (8765 interno)
#   - /evolution/* → Evolution Engine
#   - /result/* → Static Files
GATEWAY_PORT=8000

# UI Server (Standalone)
# Porta alternativa para acessar UI diretamente sem gateway
# Acesse em: http://localhost:8765/
UI_PORT=8765

# Evolution Server (Standalone)
# Porta para Evolution Engine standalone
# Se não configurado, roda montado no ASGI Gateway
# Acesse em: http://localhost:8002/evolution/health
EVOLUTION_HOST=0.0.0.0
EVOLUTION_PORT=8002

# Logging
LOG_LEVEL=info
LOG_TO_FILE=true

# Memory
MEMORY_STORAGE_TYPE=sqlite          # sqlite (default) | json | cbor2 — backend de STM/LTM
MEMORY_PERSISTENCE=true             # Persistir memórias entre sessões

# Metabolic Storage (consumido pelo MetabolicDataAdapter)
METABOLIC_STORAGE_TYPE=auto         # auto (default) | cbor2 | json | sqlite
                                    # auto = todas as fontes (epigenetic + pools + sqlite)
                                    # cbor2 = apenas obsidian/epigenetic/*.cbor
                                    # json  = apenas pools + methylation + knowledge
                                    # sqlite = apenas STM/LTM via SQLite BLOBs

# Pipeline
PIPELINE_MAX_WORKERS=8
PIPELINE_MAX_RETRY=3
PIPELINE_MAX_LATENCY=30

# Bandit Policy
BANDIT_POLICY=epsilon_greedy
epsilon=0.2

# Sanity Barrier
SANITY_BARRIER_ENABLED=true
SANITY_BARRIER_CRITICAL_NODES=orchestrator_agent,architecture_validator,evaluator,pipeline_updater

# Toxicity Filter
TOXICITY_FILTER=true
TOXICITY_THRESHOLD=0.8

# Resource Limits
MAX_CPU_USAGE=80
MAX_MEMORY_USAGE_MB=8192

# Execution Registry
EXECUTION_REGISTRY_PERSISTENCE=true

# SearXNG (meta-buscador local)
SEARXNG_URL=http://localhost:8005

PIPELINE_TIMEOUT=300

# === CONFIGURAÇÃO LOCAL (Sem GPU, Sem Créditos HF) ===
OLLAMA_ONLY=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b

# Desativar providers cloud que não funcionam
PROVIDER_FALLBACK_CHAIN=ollama

# Desativar RAG que tenta baixar do HuggingFace
DISABLE_RAG=true
DISABLE_EMBEDDINGS=true

# You.com Search API (gratuito: 100/dia)
YDC_API_KEY=your-you-api-key-here

# Timeout maior para modelo local lento
RUNNER_TASK_TIMEOUT=600
GRAPH_EXECUTION_TIMEOUT=600

# ===========================================
# GERAÇÃO 2 - BANDITPOLICY EVOLUTIVA
# ===========================================
# Ativar BanditPolicy Evolutiva (default: false)
USE_BANDIT_EVOLUTIVA=false

# Configurações da BanditPolicy Evolutiva
BANDIT_EPSILON=0.2        # Taxa de exploração (0.0-1.0)
BANDIT_DECAY=0.995        # Decay do epsilon por iteração
BANDIT_DB_PATH=iaglobal/memory/bandit_evolutivo.json

# Thresholds de evolução
BANDIT_MIN_FITNESS=0.3    # Fitness mínimo para seleção
BANDIT_BAN_DURATION=24    # Duração de banimento em horas
