# Configuration for IAGlobal v3+ Pipeline
# Copy this to .env before running the pipeline

# Provider configuration
PROVIDER_TIMEOUT=30
PROVIDER_FALLBACK_CHAIN=ollama,groq,nvidia,openrouter,opencode,gemini

# Ollama models
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_HOST=http://localhost:11434

# Groq API
GROQ_API_KEY=your-groq-api-key-here

# NVIDIA API
NVIDIA_API_KEY=your-nvidia-api-key-here

# OpenRouter API
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenCode API
OPENCODE_API_KEY=your-opencode-api-key-here

# Google GenAI
GEMINI_API_KEY=your-gemini-api-key-here

# Logging
LOG_LEVEL=info
LOG_TO_FILE=true

# Memory
MEMORY_STORAGE_TYPE=sqlite
MEMORY_PERSISTENCE=true

# Pipeline
PIPELINE_MAX_WORKERS=8
PIPELINE_MAX_RETRY=3
PIPELINE_MAX_LATENCY=30

# Bandit Policy
BANDIT_POLICY=epsilon_greedy
epsilon=0.2

# Sanity Barrier
SANITY_BARRIER_ENABLED=true
SANITY_BARRIER_CRITICAL_NODES=orchestrator_agent,architecture_validator,evaluator,pipeline_updater

# Toxicity Filter
TOXICITY_FILTER=true
TOXICITY_THRESHOLD=0.8

# Resource Limits
MAX_CPU_USAGE=80
MAX_MEMORY_USAGE_MB=8192

# Execution Registry
EXECUTION_REGISTRY_PERSISTENCE=true

