# Local model and provider defaults
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_URL=http://localhost:11434
DEFAULT_OLLAMA_MODEL=qwen2.5:0.5b
PROVIDER_TIMEOUT=30

# Local search service
SEARXNG_URL=http://localhost:8005

# Storage backends
MEMORY_STORAGE_TYPE=sqlite
METABOLIC_STORAGE_TYPE=auto

# Bandit and pipeline defaults
BANDIT_POLICY=epsilon_greedy
PIPELINE_MAX_WORKERS=8

# Evolution Server (standalone)
EVOLUTION_HOST=0.0.0.0
EVOLUTION_PORT=8002

# Optional cloud credentials (leave empty for local-only operation)
GROQ_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
OPENCODE_API_KEY=
HUGGINGFACE_API_KEY=
OPENAI_API_KEY=
BRAVE_API_KEY=
TAVILY_API_KEY=
SERP_API_KEY=
EXA_API_KEY=
POE_API_KEY=
